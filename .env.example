# Binance API credentials (spot + USDT-M futures trading; never enable withdraw)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Set to "true" to point REST+WS at testnet.binance.vision / testnet.binancefuture.com
BINANCE_TESTNET=true

# Execution mode: backtest | paper | live
BOT_MODE=paper

# Strategy parameters (APR in decimal: 0.10 = 10% annualised)
FUNDING_ENTRY_APR=0.10
FUNDING_EXIT_APR=0.03

# Risk
MAX_NOTIONAL_USDT=500
MARGIN_BUFFER_MULT=3.0
MAX_DELTA_PCT=0.02
STALE_TICK_SECONDS=5

# Logging
LOG_LEVEL=INFO
